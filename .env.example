GEMINI_API_KEY=
RAILWAY_PUBLIC_URL=https://your-service.up.railway.app

# Wolf Capital — Supabase Postgres (never commit real credentials)
SUPABASE_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
# DATABASE_URL=postgresql://...  # optional alias accepted by db/connection.py
SUPABASE_PROJECT_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co  # alias also accepted
SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # optional; preferred for server-side health upserts

# Phase F — ops health dashboard (FastAPI + HTML, Google OAuth via Supabase PKCE)
AUTHORIZED_EMAIL=you@example.com
APP_REDIRECT_URL=http://127.0.0.1:8000/health/auth/callback
# When UI is on Vercel, set this to your Vercel callback instead, e.g.
# https://your-app.vercel.app/health/auth/callback (also add in Supabase Auth)
DASHBOARD_SESSION_SECRET=change-me
# Vercel frontend URL — used for OAuth callback + post-login redirect
FRONTEND_URL=https://your-app.vercel.app

# Zerodha Kite Connect
KITE_API_KEY=
KITE_API_SECRET=
# Daily auto-login (optional — enables headless token refresh)
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=
